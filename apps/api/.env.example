DATABASE_URL=postgresql+asyncpg://kiwi:kiwi_dev_password@localhost:5432/kiwios
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Single-user bootstrap (admin) — used by /api/auth/login.
# Generate JWT_SECRET via: python -c "import secrets; print(secrets.token_urlsafe(64))"
ADMIN_EMAIL=mathias@kiwi.local
ADMIN_PASSWORD=change-me-on-first-boot

# Cookie flags for the refresh token. Set COOKIE_SECURE=true behind HTTPS.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

CORS_ORIGINS=["http://localhost:3000"]

GITHUB_TOKEN=
GITHUB_USERNAME=Kiwi6212
GITHUB_CACHE_TTL_SECONDS=900
